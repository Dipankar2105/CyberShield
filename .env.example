# CyberShield Environment Variables
# Copy this file to .env and fill in your API keys

# Gemini API Key (required) - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Together AI API Key (optional fallback) - Get from https://api.together.xyz
TOGETHER_API_KEY=your_together_api_key

# OpenRouter API Key (optional fallback) - Get from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key

# VirusTotal API Key (for file/URL scanning) - Get from https://virustotal.com
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# Google Safe Browsing API Key - Get from https://console.cloud.google.com
SAFE_BROWSING_API_KEY=your_safe_browsing_api_key

# HaveIBeenPwned API Key (optional) - Get from https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your_hibp_api_key

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/cybershield
